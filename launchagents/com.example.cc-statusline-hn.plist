<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.cc-statusline-hn</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>__INSTALL__/fetch-hn.sh</string>
  </array>

  <key>StartInterval</key>
  <integer>3600</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__HOME__/.claude/cache/latest-hn.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME__/.claude/cache/latest-hn.stderr.log</string>

  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
